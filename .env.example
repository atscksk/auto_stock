TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=

MODE=DRY_RUN
LIVE_CONFIRM=NO

SYMBOL=069500
ORDER_BUDGET_KRW=300000

ORDER_TYPE=LIMIT
PRICE_SLIPPAGE_RATE=0.001

MIN_CANDLES=20
MA_WINDOW=20
BUY_THRESHOLD=1.03
SELL_THRESHOLD=0.97

LOG_LEVEL=info

# Optional notification webhooks for future alerting integrations.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=
ENABLE_NOTIFICATIONS=true

# DRY_RUN only. If set, risk check uses this simulated buying power instead of API buying power.
DRY_RUN_BUYING_POWER_KRW=

# Infinite buying live safety. LIVE buy orders are blocked unless this is set to a positive amount.
IB_LIVE_ORDER_AMOUNT_LIMIT=
